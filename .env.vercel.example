# Vercel deployment environment variables
API_HOST=0.0.0.0
API_PORT=8000

# ---- LLM Provider ----
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# ---- Vercel Mode ----
# "direct" = run LLM/RAG on Vercel (via OpenAI API)
# "proxy"  = forward to worker machine
VERCEL_MODE=direct

# ---- Database (optional for RAG) ----
DATABASE_URL=
EMBED_MODEL=text-embedding-3-small
EMBED_DIMS=768

# ---- Tavily (optional fallback) ----
TAVILY_API_KEY=

# ---- MLflow (disabled on Vercel) ----
MLFLOW_ENABLED=false

# ---- Worker (only needed if VERCEL_MODE=proxy) ----
WORKER_BASE_URL=
WORKER_SHARED_SECRET=
WORKER_TIMEOUT_SEC=180
